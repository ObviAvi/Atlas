# Neo4j AuraDB Configuration
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# Google Gemini API Configuration (used for chat / inference)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Embedding Configuration (local IBM Granite model, no API key required)
# Downloaded from HuggingFace on first use and run on CPU by default.
# See https://huggingface.co/collections/ibm-granite/granite-embedding
EMBEDDING_MODEL=ibm-granite/granite-embedding-30m-english
EMBEDDING_DEVICE=cpu
VECTOR_TOP_K=5

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
